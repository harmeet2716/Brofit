APP_NAME=FitNexus
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

DB_CONNECTION=mongodb
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DATABASE=fitnexus

# Supports both standard OpenAI API keys and OpenRouter Keys (starting with sk-or-)
OPENAI_API_KEY=your_openai_or_openrouter_api_key_here

MAIL_MAILER=log
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
